# Copy to .env and fill in only the providers you use. Do not commit .env.

# Embeddings: voyage, openai, or local. Use local only for offline smoke tests.
EMBEDDING_PROVIDER=voyage
EMBEDDING_MODEL=voyage-3
VOYAGE_API_KEY=

# OpenAI embedding fallback.
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=

# Reranking: voyage is the production default. Use local only for offline smoke tests.
RERANK_PROVIDER=voyage
RERANK_MODEL=rerank-2

# Chat: anthropic, bedrock, codex, or mock. Use mock only for offline smoke tests.
CHAT_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# Anthropic Bedrock mode uses normal AWS credential resolution.
# CHAT_PROVIDER=bedrock
# AWS_REGION=us-east-1

# Codex CLI mode uses your local Codex login/config. This is not necessarily a
# local model unless CODEX_OSS=true and a local provider is configured.
# CHAT_PROVIDER=codex
# CODEX_BIN=codex
# CODEX_MODEL=
# CODEX_OSS=false
# CODEX_LOCAL_PROVIDER=

# Optional storage overrides.
# RAG_DATA_DIR=./data
# TRANSCRIPTS_DIR=./transcripts/lordofspirits
# LANCEDB_DIR=./data/lancedb
# CHUNK_CATALOG=./data/chunks.jsonl
# EMBEDDING_CACHE=./data/embedding_cache.jsonl
# PERSONAS_DIR=./personas
